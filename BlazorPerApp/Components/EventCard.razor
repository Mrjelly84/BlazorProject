@using BlazorPerApp.Models

<EditForm Model="Event" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="event-card card p-3">
        <div class="mb-2">
            <label class="form-label">Title</label>
            <InputText class="form-control" @bind-Value="Event.Title" />
            <ValidationMessage For="() => Event.Title" />
        </div>

        <div class="mb-2">
            <label class="form-label">Date</label>
            <InputDate class="form-control" @bind-Value="Event.Date" />
            <ValidationMessage For="() => Event.Date" />
        </div>

        <div class="mb-2">
            <label class="form-label">Description</label>
            <InputTextArea class="form-control" @bind-Value="Event.Description" />
            <ValidationMessage For="() => Event.Description" />
        </div>

        <div class="form-check">
            <InputCheckbox class="form-check-input" @bind-Value="Event.IsAttending" />
            <label class="form-check-label">Attending</label>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Save</button>
        </div>
    </div>
</EditForm>

@inject BlazorPerApp.Services.LogStorage _logStorage
@inject Microsoft.Extensions.Logging.ILogger<EventCard> _logger

@code {
    [Parameter]
    public EventItem Event { get; set; } = new EventItem();

    [Parameter]
    public EventCallback<EventItem> EventChanged { get; set; }

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    private string? errorMessage;

    private async Task HandleValidSubmit()
    {
        try
        {
            errorMessage = null;
            await EventChanged.InvokeAsync(Event);
            if (OnValidSubmit.HasDelegate)
            {
                await OnValidSubmit.InvokeAsync();
            }
        }
        catch (System.Exception ex)
        {
            errorMessage = ex.Message;
            try
            {
                await _logStorage.AppendAsync(new Models.LogEntry
                {
                    Timestamp = System.DateTime.UtcNow,
                    Level = "Error",
                    Category = nameof(EventCard),
                    Message = ex.Message,
                    Exception = ex.ToString()
                });
            }
            catch { }
            _logger?.LogError(ex, "Unhandled exception during EventCard submit");
        }
    }
}
